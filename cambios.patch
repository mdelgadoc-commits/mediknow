+@login_required(login_url="login")
+@require_http_methods(["GET"])
+def pacientes(request):
+    """Listado de pacientes registrados por el medico autenticado."""
+    query = request.GET.get("q", "").strip()
+    patients = Patient.objects.filter(doctor=request.user).prefetch_related("allergies")
+    if query:
+        patients = patients.filter(full_name__icontains=query) | patients.filter(code__icontains=query)
+    patients = patients.order_by("-created_at")
+    context = {"patients": patients, "query": query}
+    return render(request, "core/pacientes.html", context)
+
+
+@login_required(login_url="login")
+@require_http_methods(["GET"])
+def doctores(request):
+    """Listado de medicos (usuarios) registrados en el sistema."""
+    doctors = User.objects.annotate(patient_count=Count("patients")).order_by("first_name", "last_name", "username")
+    context = {"doctors": doctors}
+    return render(request, "core/doctores.html", context)
+
+
